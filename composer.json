{
  "name": "memran/marwa-ai",
  "description": "A comprehensive AI abstraction library for PHP with multi-provider support",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Mohammad Emran",
      "email": "memran.dhk@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "guzzlehttp/guzzle": "^7.9",
    "memran/marwa-logger": "^1.0",
    "memran/marwa-error-handler": "^1.1",
    "memran/marwa-event": "^0.2",
    "psr/event-dispatcher": "^1.0",
    "league/container": "^5.1",
    "symfony/console": "^7.3",
    "memran/marwa-support": "^1.3.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "mockery/mockery": "^1.6",
    "friendsofphp/php-cs-fixer": "^3.21",
    "phpstan/phpstan": "^1.10"
  },
  "autoload": {
    "psr-4": {
      "Marwa\\AI\\": "src/"
    },
    "files": [
      "src/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Marwa\\AI\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "analyse": "phpstan analyse --memory-limit=256M",
    "test": "phpunit",
    "lint": "php-cs-fixer fix --dry-run --diff",
    "fix": "php-cs-fixer fix"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
